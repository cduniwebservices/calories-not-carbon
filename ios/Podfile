platform :ios, '13.0'

require_relative File.join('Flutter', 'generated_tool_utils.rb')

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['SWIFT_VERSION'] = '5.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'
      config.build_settings['DEFINES_MODULE'] = 'YES'

      # Permission Handler macros
      existing = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
      defs = existing.nil? ? ['$(inherited)'] : (existing.is_a?(String) ? existing.split(' ') : existing.dup)
      ['PERMISSION_LOCATION=1', 'PERMISSION_NOTIFICATIONS=1', 'PERMISSION_SENSORS=1'].each do |p|
        defs << p unless defs.include?(p)
      end
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs
    end
  end
end
