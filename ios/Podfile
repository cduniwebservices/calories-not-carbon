platform :ios, '13.0'

# Standard Flutter requirement for plugin linking
flutter_install_all_ios_pods_path = File.join('Flutter', 'generated_tool_utils.rb')
if File.exist?(flutter_install_all_ios_pods_path)
  require_relative flutter_install_all_ios_pods_path
else
  # Mock methods to satisfy CocoaPods until Flutter generates the real ones
  def flutter_ios_podfile_setup; end
  def flutter_install_all_ios_pods(path); end
  def flutter_additional_ios_build_settings(target); end
end

# Essential Flutter setup call
flutter_ios_podfile_setup

# Force all plugins to be built as frameworks
use_frameworks!
use_modular_headers!

target 'Runner' do
  # This will install all Flutter plugins
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  # Apply settings to the main Runner project
  installer.aggregate_targets.each do |target|
    target.user_project.targets.each do |user_target|
      if user_target.name == 'Runner'
        user_target.build_configurations.each do |config|
          config.build_settings['DEFINES_MODULE'] = 'YES'
          config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'
        end
      end
    end
    target.user_project.save
  end

  installer.pods_project.targets.each do |target|
    # Apply standard Flutter settings
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # Ensure deployment target is at least 13.0 for all pods
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      
      # Standardize Swift version and bitcode
      config.build_settings['SWIFT_VERSION'] = '5.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      
      # Enhance module compatibility (CRITICAL for app_links)
      config.build_settings['DEFINES_MODULE'] = 'YES'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
      
      # Ensure modules are enabled for the compiler
      config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'
    end

    # Inject Permission Handler Macros
    target.build_configurations.each do |config|
      existing_defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
      if existing_defs.nil?
        definitions = ['$(inherited)']
      elsif existing_defs.is_a?(String)
        definitions = existing_defs.split(' ')
      else
        definitions = existing_defs.dup
      end
      
      # Permission Handler macros
      ['PERMISSION_LOCATION=1', 'PERMISSION_NOTIFICATIONS=1', 'PERMISSION_SENSORS=1'].each do |perm|
        definitions << perm unless definitions.include?(perm)
      end
      
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = definitions
    end
  end
end
