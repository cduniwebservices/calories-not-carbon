platform :ios, '13.0'

# Dynamically locate and load Flutter's build hooks if they exist
# In fresh CI environments, these may not exist until the first build run
flutter_install_all_ios_pods_path = File.join('Flutter', 'generated_tool_utils.rb')
if File.exist?(flutter_install_all_ios_pods_path)
  require_relative flutter_install_all_ios_pods_path
end

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # standard flutter pod installation
  if defined?(flutter_install_all_ios_pods)
    flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    # standard flutter build settings
    if defined?(flutter_additional_ios_build_settings)
      flutter_additional_ios_build_settings(target)
    end
    
    # Permission Handler Configuration (Million-Dollarsnappiness)
    target.build_configurations.each do |config|
      existing_defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
      if existing_defs.nil?
        definitions = ['$(inherited)']
      elsif existing_defs.is_a?(String)
        definitions = existing_defs.split(' ')
      else
        definitions = existing_defs.dup
      end
      
      # Mandatory permission macros for iOS popups
      ['PERMISSION_LOCATION=1', 'PERMISSION_NOTIFICATIONS=1', 'PERMISSION_SENSORS=1'].each do |perm|
        definitions << perm unless definitions.include?(perm)
      end
      
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = definitions
    end
  end
end
